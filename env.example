# Django SchoolApp Environment Configuration
# Copy this file to .env and modify the values as needed

# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100,192.168.1.101
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://192.168.1.100,http://192.168.1.101

# Database Configuration (PostgreSQL)
DB_NAME=multi_sis_database
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_HOST=db
DB_PORT=5432

# Email Configuration (Optional - set DISABLE_EMAIL_SENDING=True to disable)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
DISABLE_EMAIL_SENDING=False

# Google OAuth2 Configuration (Optional)
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=your-google-oauth2-key
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=your-google-oauth2-secret

# Session Configuration
SESSION_COOKIE_AGE=36000000
ADMIN_EMAIL=admin@example.com
SITE_URL=http://localhost
